# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/

# PyInstaller
*.spec

# npm platform binaries (published to npm, not git)
npm/platforms/*/bin/

# Virtual environments
.venv/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Project-specific
.claude/
*.db
*.db-wal
*.db-shm

# Sensitive data — NEVER commit
*.json
!pyproject.toml
!npm/**/package.json
.env
.env.*
!.env.example

# Temp files
*.tmp
*.bak

# Local generated outputs — never commit (may contain private chat data)
output/*
!output/README.md
